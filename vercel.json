{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/match", "destination": "/api/match" },
    { "source": "/group", "destination": "/api/group" },
    { "source": "/r32", "destination": "/api/r32" },
    { "source": "/countdown", "destination": "/api/countdown" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "image/svg+xml; charset=utf-8" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    }
  ]
}
